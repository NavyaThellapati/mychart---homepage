# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mychart

# Authentication
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1h

# Express
PORT=5001
NODE_ENV=development

# Comma-separated frontend origins allowed by CORS
CLIENT_URL=http://127.0.0.1:5173
CLIENT_URLS=http://127.0.0.1:5173,http://localhost:5173

# Vite frontend API origin
VITE_API_URL=http://localhost:5001

# Optional SMTP password reset email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="MyChart Portal <your-email@gmail.com>"
