    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.3",
    "lucide-react": "^0.453.0",
    "nodemailer": "^8.0.9",
    "pg": "^8.22.0",
    "react": "^18.2.0",
